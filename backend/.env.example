# Server Configuration
NODE_ENV=production
PORT=3001

# Database Configuration
# Para Railway com PostgreSQL (Railway fornece automaticamente)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Para desenvolvimento local com SQLite
# DATABASE_URL="file:./dev.db"

# JWT Secret (gere uma chave secreta forte para produção)
JWT_SECRET=sua-chave-secreta-super-segura-aqui

# Admin Credentials (usado no seed inicial)
ADMIN_EMAIL=admin@anacurve.com.br
ADMIN_PASSWORD=senha-segura-admin

# Cloudinary (armazenamento de imagens)
# Crie uma conta em cloudinary.com e copie do Dashboard
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=seu-api-secret

# Mercado Pago Credentials
# IMPORTANTE: Use credenciais de PRODUÇÃO em produção
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxx-xxxxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxx-xxxxxx-xxxx-xxxx-xxxxxxxxxxxx

# CORS Configuration
# URL do frontend (Vercel) - adicione sem barra no final
CLIENT_URL=https://seu-frontend.vercel.app

# URLs (para referência)
FRONTEND_URL=https://seu-frontend.vercel.app
BACKEND_URL=https://seu-backend.railway.app
